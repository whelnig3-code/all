# .env.production — 운영 환경 기본값
# ────────────────────────────────────────────────────────────────────────────
# ✅ Git 추적 가능 (비밀 정보 없음)
# ❌ 아래 항목은 절대 여기에 넣지 마세요:
#    DASHBOARD_SECRET, ANTHROPIC_API_KEY, PROJECT_BASE_DIR, PORT
#    → 이 값들은 머신마다 다르거나 민감 정보이므로 .env.local에 설정

# ── 에이전트 라우팅 ────────────────────────────────────────────────────────
ENABLE_ROUTING_DEBUG=false
ENABLE_SHADOW_MULTI_HOP=true
ENABLE_SHADOW_SCORING=false

# ── Phase 1: Depth Policy ─────────────────────────────────────────────────
DEPTH_STRATEGY=hard-cap
MAX_HOP_LIMIT=3
ENABLE_COST_SIMULATION=true
MAX_LATENCY_BUDGET_MS=60000
MAX_TOKEN_BUDGET=5000

# ── Phase 2: Multi-Hop 실행 ───────────────────────────────────────────────
ENABLE_MULTI_HOP_EXECUTION=true
RUNTIME_BUDGET_MS=120000
SOFT_BUDGET_MS=95000

# ── Phase 3: LLM Candidate ────────────────────────────────────────────────
# 운영 기본값: false (보수적 유지)
# 실험 활성화: .env.local에서 ENABLE_LLM_CANDIDATE=true + ANTHROPIC_API_KEY 설정
# 시뮬레이션 검증 완료: T=8 → 채택률 15.0%, ΔHop +0.15 (2026-03-02)
ENABLE_LLM_CANDIDATE=false
LLM_CANDIDATE_MAX=1
LLM_CANDIDATE_SCORE_THRESHOLD=8
