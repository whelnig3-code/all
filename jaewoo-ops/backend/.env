# ──────────────────────────────────────────
# JAEWOO OPS — 환경 변수 설정
# ──────────────────────────────────────────

# 앱 기본 설정
APP_ENV=development
SECRET_KEY=dev-secret-key-change-in-production-min-32chars!!

# Excel 파일 경로 (Phase 1)
EXCEL_FILE_PATH=../excel/JAEWOO_OPS_운영대장.xlsx

# 완료 링크 베이스 URL
BASE_URL=http://localhost:8000

# ── 카카오 알림톡 (SOLAPI) ── 실제 키 입력 전까지 더미값 유지
SOLAPI_API_KEY=dummy
SOLAPI_API_SECRET=dummy
SOLAPI_SENDER_PHONE=01000000000
SOLAPI_KAKAO_PF_ID=dummy

# ── 카카오워크 봇 ──
KAKAOWORK_BOT_TOKEN=dummy

# ── 구글 번역 API (외국인 챗봇용, 선택사항) ──
GOOGLE_TRANSLATE_API_KEY=

# ── SMS 대체 발송 (기본 OFF) ──
SMS_FALLBACK_ENABLED=false

# ── 알림 정책 ──
MAX_DAILY_ALERTS=2
COMPLETION_TOKEN_TTL_HOURS=72
