# JM Agent Team 환경 설정 예시
# 이 파일을 .env.local로 복사 후 값을 채워 사용하세요.
# ────────────────────────────────────────────────

# 실행 모드: sdk 또는 api
CLAUDE_CODE_MODE=sdk

# API 키 (api 모드 전용)
# ANTHROPIC_API_KEY=sk-ant-...

PORT=3000
PROJECT_BASE_DIR=C:/Users/user/Desktop/claude-agent-team
DASHBOARD_SECRET=

ENABLE_REMOTE_ACCESS=false
TUNNEL_TYPE=quick
TUNNEL_NAME=jm-dashboard
