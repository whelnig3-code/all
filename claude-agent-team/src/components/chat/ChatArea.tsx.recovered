// 파일 크기 최대 1MB (초과 시 내용 생략)
const MAX_FILE_SIZE = 1024 * 1024;

// 텍스트 파일 확장자 목록
const TEXT_EXTENSIONS = new Set([
  "ts", "tsx", "js", "jsx", "json", "md", "txt", "py", "go",
  "rs", "java", "c", "cpp", "h", "css", "html", "xml", "yaml",
  "yml", "toml", "sh", "bash", "zsh", "env", "gitignore",
  "dockerfile", "sql", "graphql", "vue", "svelte", "prisma",
  "lock", "ini", "cfg", "conf", "log", "csv",
]);

/** 파일의 종류(text/image/binary) 판단 */
function detectKind(file: File): FileAttachmentKind {
  if (file.type.startsWith("image/")) return "image";
  const ext = file.name.split(".").pop()?.toLowerCase() ?? "";
  if (file.type.startsWith("text/") || TEXT_EXTENSIONS.has(ext)) return "text";
  return "binary";
}

/** 파일 내용을 읽어 문자열로 반환 */
function readFileContent(file: File, kind: FileAttachmentKind): Promise<string> {
  return new Promise((resolve, reject) => {
    // 크기 초과 시 안내 문구 반환
    if (file.size > MAX_FILE_SIZE) {
      resolve(`[파일 크기 초과: ${(file.size / 1024).toFixed(1)}KB — 최대 1MB 지원]`);
      return;
    }
    const reader = new FileReader();
    reader.onerror = () => reject(new Error(`"${file.name}" 읽기 실패`));
    reader.onload = (e) => resolve((e.target?.result as string) ?? "");
    if (kind === "image") {
      reader.readAsDataURL(file);
    } else if (kind === "text") {
      reader.readAsText(file, "utf-8");
    } else {
      // 바이너리 파일은 내용 미리보기 불가 안내
      resolve(`[바이너리 파일: ${file.name} (${file.type || "알 수 없는 형식"})]`);
    }
  });
}

