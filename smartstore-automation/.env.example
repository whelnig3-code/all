# ==============================
# 스마트스토어 자동화 환경변수
# ==============================

# 데이터베이스
DATABASE_URL=postgresql://user:password@localhost:5432/smartstore

# 암호화 키 (32바이트 필수, hex 64자 권장)
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MASTER_ENCRYPTION_KEY=

# 네이버 커머스 API
NAVER_CLIENT_ID=
NAVER_CLIENT_SECRET=
NAVER_SHOP_ID=
NAVER_COMMERCE_API_BASE_URL=https://api.commerce.naver.com

# 번역 서비스 (무료: google-free, 유료: deepl)
TRANSLATOR_ADAPTER=google-free
DEEPL_API_KEY=

# 알림 서비스 (기본: telegram, 유료: sms)
NOTIFICATION_ADAPTER=telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# SMS (알림 어댑터가 sms일 때)
SMS_API_KEY=
SMS_FROM_NUMBER=

# LLM (기본: ollama, 유료: openai)
LLM_ADAPTER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OPENAI_API_KEY=

# Redis (BullMQ 큐)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# 구매대행 활성화 (Phase 5+, 현재 비활성화)
SOURCING_ALIEXPRESS_ENABLED=false
SOURCING_TAOBAO_ENABLED=false

# 환율 API
EXCHANGE_RATE_API_KEY=

# 가격 모니터링
PRICE_MONITOR_INTERVAL_MS=3600000

# 운영 관리 API Basic Auth
# ⚠️ ADMIN_PASS는 반드시 강력한 값으로 변경 — 기본값 "changeme" 사용 시 서버 기동 차단됨
# 생성: node -e "console.log(require('crypto').randomBytes(24).toString('base64'))"
ADMIN_USER=admin
ADMIN_PASS=

# 대시보드 서버 전용 (apps/dashboard/.env.local에 별도 설정)
# INTERNAL_API_BASE=http://localhost:3000   # API 서버 내부 URL (대시보드 프록시용)
# ⚠️ NEXT_PUBLIC_ADMIN_PASS 절대 사용 금지 — 프록시 구조를 통해 비밀번호 노출 차단됨
#
# 프록시 접근 토큰 (브라우저 접근 제한용 — ADMIN_PASS와 별개)
# 생성: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# ADMIN_PROXY_TOKEN=              # 서버 전용 — 토큰 검증에 사용 (브라우저 미노출)
# NEXT_PUBLIC_ADMIN_PROXY_TOKEN=  # ADMIN_PROXY_TOKEN과 동일 값 — 브라우저에서 x-admin-token 헤더로 전송

# Kill Switch (false로 설정 시 해당 자동화 기능 즉시 비활성화)
AUTO_PRICE_ENABLED=true
AUTO_ORDER_ENABLED=true
AUTO_SHIPPING_ENABLED=true

# 다중 계정 운영 (계정별 워커 인스턴스에 각각 다른 값 설정)
# 예: account1, account2, account3, account4
ACCOUNT_ID=default

# 이미지 파이프라인 (Phase 3)
OCR_ENGINE=paddleocr
TRANSLATION_MODEL=qwen2.5:7b-instruct
IMAGE_FONT_PATH=                        # 한글 폰트 경로 (예: /usr/share/fonts/truetype/nanum/NanumGothic.ttf)
IMAGE_OUTPUT_DIR=./data/generated       # 이미지 임시 저장 디렉토리
NAVER_IMAGE_UPLOAD_ENABLED=true         # false로 설정 시 업로드 건너뜀

# 네이버 블로그 자동 포스팅 (P3)
# ⚠️ 기본 false — OAuth 토큰 발급 후 true로 전환
# 토큰 발급: https://developers.naver.com/docs/login/devguide/ → 블로그 권한 포함
BLOG_POSTING_ENABLED=false
NAVER_BLOG_ACCESS_TOKEN=               # OAuth 2.0 Bearer 토큰

# 시스템
NODE_ENV=development
LOG_LEVEL=debug
PORT=3100
