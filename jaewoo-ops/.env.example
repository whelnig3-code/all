# ──────────────────────────────────────────
# JAEWOO OPS — 환경 변수 설정 예시
# 이 파일을 복사하여 .env 로 저장 후 값을 채워주세요.
# ──────────────────────────────────────────

# 앱 기본 설정
APP_ENV=development
SECRET_KEY=your-secret-key-change-this-in-production

# Excel 파일 경로 (Phase 1)
EXCEL_FILE_PATH=./excel/JAEWOO_OPS_운영대장.xlsx

# 완료 링크 베이스 URL
BASE_URL=http://localhost:8000

# ── 카카오 알림톡 (SOLAPI) ──
SOLAPI_API_KEY=
SOLAPI_API_SECRET=
SOLAPI_SENDER_PHONE=
SOLAPI_KAKAO_PF_ID=

# ── 카카오워크 봇 ──
KAKAOWORK_BOT_TOKEN=

# ── SMS 대체 발송 (기본 OFF) ──
SMS_FALLBACK_ENABLED=false

# ── 알림 정책 ──
MAX_DAILY_ALERTS=2
COMPLETION_TOKEN_TTL_HOURS=72
